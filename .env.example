DATABASE_URL="postgresql://user:password@host:5432/isp_cobranca"

# SGP / Hubsoft
SGP_BASE_URL=https://api.seusgp.com.br
SGP_CLIENT_ID=seu_client_id
SGP_CLIENT_SECRET=seu_client_secret
SGP_USERNAME=seu_usuario
SGP_PASSWORD=sua_senha
SGP_GRANT_TYPE=password
SGP_TIMEOUT_MS=30000
SGP_CLIENTS_URL=/api/v1/integracao/cliente/todos
SGP_INVOICES_URL=/api/v1/integracao/financeiro/faturas
SGP_HOLIDAYS_URL=/api/v1/integracao/feriados

# Evolution API (WhatsApp)
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key
EVOLUTION_INSTANCE=default

# App
CRON_SECRET=troque-em-producao-123
NEXT_PUBLIC_APP_NAME=ISP Cobrança
NODE_ENV=development
TZ=America/Sao_Paulo

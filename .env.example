DATABASE_URL="postgresql://user:password@host:5432/isp_cobranca"

# SGP TSMX — https://documenter.getpostman.com/view/6682240/2sB34hHg2V
# URL do seu SGP (sem barra no final)
SGP_BASE_URL=https://suaempresa.sgp.net.br
# Token e App: Administração → Integrações → Tokens no painel SGP
SGP_TOKEN=seu_token_aqui
SGP_APP=nome_da_aplicacao
SGP_TIMEOUT_MS=30000
# Endpoints (padrão SGP — altere só se a sua versão usar paths diferentes)
SGP_URA_CLIENTES_URL=/api/ura/clientes/
SGP_CONSULTA_CLIENTE_URL=/api/ura/consultacliente/
SGP_TITULOS_URL=/api/central/titulos/
SGP_CONTRATOS_URL=/api/central/contratos

# Evolution API (WhatsApp)
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key
EVOLUTION_INSTANCE=default

# App
CRON_SECRET=troque-em-producao-123
NEXT_PUBLIC_APP_NAME=ISP Cobrança
# Nome da empresa exibido nas mensagens de cobrança
NEXT_PUBLIC_COMPANY_NAME=Minha Telecom
# WhatsApp de atendimento (exibido nos estágios D+10 e D+14)
NEXT_PUBLIC_COMPANY_WHATSAPP=(44) 99999-9999
NODE_ENV=development
TZ=America/Sao_Paulo

# Auth (NextAuth)
NEXTAUTH_URL=https://suaapp.dominio.com
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
